# Frontend Environment Configuration

# Backend API URL
# Development (.env.local): Use your local or Replit backend
# Production (Vercel): Set this in Vercel Environment Variables
VITE_API_URL=https://16523707-c83d-4a58-bfd3-b37d1ee6a655-00-av1910ck9ero.pike.replit.dev/api
# Gemini API Key (optional, for AI features)
GEMINI_API_KEY=

# SETUP INSTRUCTIONS:
# 
# 1. LOCAL DEVELOPMENT:
#    - Copy this file to .env.local
#    - Set VITE_API_URL to your backend URL (Replit, Render, or local)
#    - This file is in .gitignore and won't be committed
#
# 2. VERCEL DEPLOYMENT:
#    - Leave VITE_API_URL empty in .env (commit to git)
#    - In Vercel Dashboard: Settings → Environment Variables
#    - Add: VITE_API_URL=https://your-backend-url.com/api
#    - Redeploy the project
#
# BACKEND URL EXAMPLES:
# - Replit: https://xxxx-xxxx-xxxx.pike.replit.dev/api
# - Render: https://your-app.onrender.com/api  
# - Fly.io: https://your-app.fly.dev/api
# - Custom: https://api.yourdomain.com/api
